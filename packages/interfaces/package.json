{
  "name": "@repo/interfaces",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Shared Interfaces for Bestellando",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./address": {
      "types": "./dist/address.interface.d.ts",
      "default": "./dist/address.interface.js"
    },
    "./opening-hours": {
      "types": "./dist/opening-hours.interface.d.ts",
      "default": "./dist/opening-hours.interface.js"
    },
    "./restaurant": {
      "types": "./dist/restaurant.interface.d.ts",
      "default": "./dist/restaurant.interface.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:^",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^25.3.3",
    "@types/react": "19.2.2",
    "geojson": "^0.5.0"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.21",
    "appwrite": "^22.4.1",
    "class-validator": "^0.15.1",
    "geojson": "^0.5.0",
    "react": "^19.2.0"
  }
}
